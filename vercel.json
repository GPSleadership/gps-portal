{
  "rewrites": [
    { "source": "/client",             "destination": "/client.html"             },
    { "source": "/coach",              "destination": "/coach.html"              },
    { "source": "/survey",             "destination": "/survey.html"             },
    { "source": "/diagnostic-leader",  "destination": "/diagnostic-leader.html"  },
    { "source": "/diagnostic-coach",   "destination": "/diagnostic-coach.html"   },
    { "source": "/diagnostic-survey",  "destination": "/diagnostic-survey.html"  },
    { "source": "/diagnostic-sandbox", "destination": "/diagnostic-sandbox.html" }
  ],
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/survey-reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/diagnostic-reminders",
      "schedule": "0 14 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS, GET" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/client",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/coach",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    }
  ]
}
