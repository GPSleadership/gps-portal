{
  "rewrites": [
    {
      "source": "/client",
      "destination": "/client.html"
    },
    {
      "source": "/coach",
      "destination": "/coach.html"
    },
    {
      "source": "/coach-emergency",
      "destination": "/coach-emergency.html"
    },
    {
      "source": "/survey",
      "destination": "/survey.html"
    },
    {
      "source": "/diagnostic-leader",
      "destination": "/diagnostic-leader.html"
    },
    {
      "source": "/diagnostic-survey",
      "destination": "/diagnostic-survey.html"
    },
    {
      "source": "/decision-room",
      "destination": "/decision-room.html"
    },
    {
      "source": "/feedback",
      "destination": "/feedback.html"
    },
    {
      "source": "/diagnostic-sandbox",
      "destination": "/diagnostic-sandbox.html"
    },
    {
      "source": "/workshop-room",
      "destination": "/workshop-room.html"
    },
    {
      "source": "/workshop-survey",
      "destination": "/workshop-survey.html"
    },
    {
      "source": "/workshop-poc",
      "destination": "/workshop-poc.html"
    },
    {
      "source": "/recover",
      "destination": "/recover.html"
    }
  ],
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/survey-reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/diagnostic?action=reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/workshop-data?action=reminders",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/diagnostic?action=send-scheduled",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/survey?action=send-scheduled",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/diagnostic?action=trial-sweep",
      "schedule": "30 13 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS, GET"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/client",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/coach",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "functions": {
    "api/diagnostic.js": {
      "maxDuration": 300
    },
    "api/testimonial.js": {
      "maxDuration": 30
    },
    "api/ask.js": {
      "maxDuration": 60
    },
    "api/notify.js": {
      "maxDuration": 30
    },
    "api/get-client.js": {
      "maxDuration": 15
    },
    "api/send-reminders.js": {
      "maxDuration": 30
    },
    "api/survey-reminders.js": {
      "maxDuration": 30
    },
    "api/survey.js": {
      "maxDuration": 60
    },
    "api/accept-terms.js": {
      "maxDuration": 15
    },
    "api/start-sprint.js": {
      "maxDuration": 15
    },
    "api/submit-closeout.js": {
      "maxDuration": 15
    },
    "api/email-templates.js": {
      "maxDuration": 15
    },
    "api/workshop-data.js": {
      "maxDuration": 120
    },
    "api/workshop-survey.js": {
      "maxDuration": 15
    },
    "api/workshop-sponsor.js": {
      "maxDuration": 15
    },
    "api/workshop-poc.js": {
      "maxDuration": 15
    },
    "api/health.js": {
      "maxDuration": 10
    },
    "api/import-clients.js": {
      "maxDuration": 30
    }
  }
}