# GPS Leadership Portal — Environment Variables
# Copy this file, fill in real values, and add to Vercel → Project Settings → Environment Variables
# NEVER commit a file with real values to GitHub

# ── Supabase (get from: supabase.com → Project Settings → API) ──────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...          # anon/public key — safe for browser
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...    # service role key — server only, never expose

# ── Claude / Anthropic (get from: console.anthropic.com → API Keys) ─────────
ANTHROPIC_API_KEY=sk-ant-api03-...
# Model used: claude-sonnet-4-6

# ── Resend Email (get from: resend.com → API Keys) ───────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Alex Tremble – GPS Leadership <alex@gpsleadership.org>
# Note: domain (gpsleadership.org) must be verified in Resend with DKIM + SPF + DMARC records

# ── Portal URLs ───────────────────────────────────────────────────────────────
PORTAL_BASE_URL=https://portal.gpsleadership.org
SITE_URL=https://portal.gpsleadership.org

# ── Internal alerts ───────────────────────────────────────────────────────────
COACH_ALERT_EMAIL=alex@gpsleadership.org

# ── Cron security (generate with: openssl rand -hex 32) ──────────────────────
CRON_SECRET=your-random-secret-string-here
# Used to authenticate manual POST triggers to cron endpoints
# Example: curl -X POST https://portal.gpsleadership.org/api/diagnostic?action=reminders \
#   -H "Authorization: Bearer $CRON_SECRET" \
#   -H "Content-Type: application/json" \
#   -d '{"manual_trigger": true}'
